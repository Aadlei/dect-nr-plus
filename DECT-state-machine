@startuml
hide empty description

'state "<b>TEMP</b>" as TEMP: <i>TEMP</i>'

'State setup'
state "<b>DECT Setup</b>" as Setup: <i>Setup of device and DECT network interface</i>
state Setup {
  state "Event callbacks" as Callbacks
  state "DECT interface creation" as Interface
  state "Device settings write" as Settings
  state "DECT stack/modem init" as Stack

  Callbacks --> Interface
  Interface --> Settings
  Settings --> Stack
}

'States PT'
state "<b>Network scan</b>" as Scan: <i>Start scan for available networks</i>
state "<b>Neighbors update</b>" as Neighbor: <i>Update neighbor lists</i>
state "<b>Association request</b>" as Assoc_Req: <i>Send association request to FT and wait for response</i>
state "<b>SYNC PT</b>" as SYNC_PT: <i>Start SYNC process as PT</i>
state SYNC_PT {
  state "SYNC TX" as SYNC_PT_TX
  state "SYNC RX" as SYNC_PT_RX
  state "Offset stored" as SYNC_PT_OFFSET

  SYNC_PT_TX --> SYNC_PT_TX: TX\nfailed
  SYNC_PT_TX --> SYNC_PT_RX: TX\nsuccess
  SYNC_PT_RX --> SYNC_PT_TX: RX\nfailed
  SYNC_PT_RX --> SYNC_PT_OFFSET: RX\nsuccess
}

'States FT'
state "<b>Network beacon</b>" as Beacon: <i>Start network beacon at given channel</i>
state "<b>Association wait</b>" as Assoc_Wait: <i>Listen for association requests</i>
state "<b>Association response</b>" as Assoc_Resp: <i>Send association response to PT</i>
state "<b>SYNC FT</b>" as SYNC_FT: <i>Start SYNC process as FT</i>

'State entry'
[*] --> Setup
Setup --> Setup: Setup\nfailed

'State transitions PT'
Setup --> Scan: Setup\nsuccess
Scan --> Scan: Timeout\n(None found)
Scan --> Neighbor: Timeout\n(FTs found)
Neighbor --> Assoc_Req: Best\nFT

Assoc_Req --> SYNC_PT: Association\nsuccess
Assoc_Req --> Scan: Association\nfailed
Assoc_Req --> Scan: Timeout
SYNC_PT --> Scan: Association\nbroken

'State exit'

@enduml